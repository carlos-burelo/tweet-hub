{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      // CLIENT
      "#components/*": [
        "./src/components/*"
      ],
      "#graphql/client": [
        "./src/graphql/index"
      ],
      "#hooks/*": [
        "./src/hooks/*"
      ],
      // SHARED
      "#mocks/*": [
        "./src/shared/mocks/*"
      ],
      "#shared/*": [
        "./src/shared/*"
      ],
      "#libs/*": [
        "./src/shared/libs/*"
      ],
      "#types": [
        "./src/shared/types/index"
      ],
      // SERVER
      "#api/*": [
        "src/pages/api/*"
      ]
    },
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
